# BEGIN claude-secret-guard
set -e -o pipefail
PATTERNS_FILE=".claude/secret-hook-patterns.txt"
ALLOW_RE='^[a-zA-Z0-9_/.-]+$'

# Enumerate all warnings files (singular + per-session variants).
warnings_files=()
for f in .claude/secret-warnings.json .claude/secret-warnings-*.json; do
  [ -f "$f" ] && warnings_files+=("$f")
done

if [ ${#warnings_files[@]} -eq 0 ]; then
  # Warnings files absent — fail CLOSED. The hook does NOT self-remove.
  # To disarm, delete the block between the BEGIN/END markers in this file
  # (requires explicit user action). External deletion of the warnings files
  # does NOT disarm the hook.
  echo "pre-commit: no .claude/secret-warnings*.json found — refusing to run without audit trail. If /jr-review reports zero remaining warnings and you want to remove this hook, delete the block between '# BEGIN claude-secret-guard' and '# END claude-secret-guard' in .git/hooks/pre-commit" >&2
  exit 1
fi
[ -s "$PATTERNS_FILE" ] || { echo "pre-commit: $PATTERNS_FILE is missing or empty" >&2; exit 1; }

# Hardcoded baseline secret patterns — written to a temp file so both
# scan loops below share one source of truth. Cannot be silently disabled
# by tampering with $PATTERNS_FILE; additive to it, never replaced.
BASELINE_PATTERNS_FILE=$(mktemp)
# Shared scratch for the staged blob. `xargs` below runs without -P, so the
# scans are sequential and one buffer is safe. Materialising the blob once
# per file (rather than once per pattern, inside the loop) is what makes a
# `git show` failure distinguishable from a clean scan.
BLOB_FILE=$(mktemp)
trap 'rm -f "$BASELINE_PATTERNS_FILE" "$BLOB_FILE"' EXIT
cat >"$BASELINE_PATTERNS_FILE" <<'PATTERNS'
AKIA[0-9A-Z]{16}
sk-ant-[a-zA-Z0-9_-]{20,200}
ghp_[a-zA-Z0-9]{36}
gho_[a-zA-Z0-9]{36}
ghs_[a-zA-Z0-9]{36}
ghu_[a-zA-Z0-9]{36}
ghr_[a-zA-Z0-9]{36}
github_pat_[a-zA-Z0-9]{22,200}
sk_live_[a-zA-Z0-9]{20,200}
sk_test_[a-zA-Z0-9]{20,200}
sk-proj-[a-zA-Z0-9_-]{20,200}
sk-svcacct-[a-zA-Z0-9_-]{20,200}
xox[bpaes]-[0-9A-Za-z-]{10,200}
xoxe\.xox[bp]-[0-9A-Za-z-]{10,200}
-----BEGIN .{0,50} PRIVATE KEY
PATTERNS

# --- scanner failure semantics ---
# WHAT THIS DEFENDS: this hook is the only secret-scan consumer that runs
#   outside a Claude session — on every `git commit`, forever, with no lead
#   agent to read an abort. It must never confuse "the scanner found nothing"
#   with "the scanner could not run". Every scan below therefore treats
#   grep exit 1 (no match) as the ONLY clean outcome; anything else blocks.
# IN SCOPE: a malformed POSIX ERE in $PATTERNS_FILE (user-writable, so this
#   is the reachable one), a grep that lacks ERE support, an unreadable
#   staged blob. All three make grep exit 2 or `git show` fail, which the
#   previous `|| true` swallowed into matched="" — i.e. into "clean".
# OUT OF SCOPE, deliberately: a secret in a format absent from the catalog
#   (internal hostname, RFC1918 address, customer name, bespoke token shape).
#   A clean scan means "no *catalogued* pattern present", never "no secret
#   present" — same known gap the Phase 7 report states. Do not re-open it
#   as a finding here; widening the catalog is a change to the catalog.

# Probe 1 — grep capability (canonical: shared/secret-patterns.md "POSIX ERE
# smoke probe"). The skill mandates this at every first-use site; the hook is
# the one consumer that never inherited it.
if ! printf 'foo\n' | grep -E '^f{1,3}o+$' >/dev/null 2>&1; then
  echo "pre-commit: [ABORT — GREP -E INCOMPATIBLE] Detected grep that lacks POSIX ERE quantifier support. Install GNU grep or set GREP=ggrep before committing." >&2
  exit 1
fi

# Probe 2 — pattern validity. Probe 1 proves grep works; it does NOT prove
# the patterns are valid EREs. A single malformed pattern makes grep exit 2
# for every file, which is the actual reachable bypass. Probe once, up front,
# rather than discovering it per-file mid-scan.
validate_patterns() {
  n=0
  while IFS= read -r pat || [ -n "$pat" ]; do
    n=$((n + 1))
    [ -z "$pat" ] && continue
    set +e
    printf '' | grep -aEn -- "$pat" >/dev/null 2>&1
    ec=$?
    set -e
    if [ "$ec" -gt 1 ]; then
      echo "pre-commit: [ABORT — INVALID SECRET PATTERN] grep rejected line $n of $1 (exit $ec). A malformed pattern makes every scan error, and an errored scan must never be read as 'no secrets found'. Fix the pattern before committing. (Pattern text not echoed.)" >&2
      exit 1
    fi
  done < "$1"
}
validate_patterns "$BASELINE_PATTERNS_FILE"
validate_patterns "$PATTERNS_FILE"

# Scan paths from each warnings file against the patterns.
# Prefer the staged blob (via `git show ":$f"`) so a user cannot stage a
# secret, scrub the working tree without re-staging, and slip it past the
# hook. Fall back to the working tree only if the path is not currently
# staged (audit trail may predate a `git rm` or rename — we still want to
# block commits that contain the flagged content).
for wf in "${warnings_files[@]}"; do
  jq -j '.warnings[].file + "\u0000"' "$wf" | \
    xargs -0 -I{} bash -c 'set -eo pipefail
      f="$1"; user_patterns="$2"; baseline_patterns="$3"; blob="$4"
      case "$f" in
        *[!a-zA-Z0-9_/.-]*|..|../*|*/..|*/../*|.*|-*|/*)
          echo "pre-commit: path failed allowlist validation: $f" >&2; exit 1 ;;
      esac
      if git cat-file -e ":$f" 2>/dev/null; then
        if ! git show ":$f" >"$blob" 2>/dev/null; then
          echo "pre-commit: FAILED — cannot read staged blob for $f; refusing to certify it clean" >&2
          exit 1
        fi
        src="$blob"
      elif [ -f "$f" ] && [ ! -L "$f" ]; then
        src="$f"
      else
        exit 0
      fi
      scan_file() {
        while IFS= read -r pat || [ -n "$pat" ]; do
          [ -z "$pat" ] && continue
          set +e
          out=$(grep -aEn -- "$pat" "$src")
          ec=$?
          set -e
          case "$ec" in
            0)
              echo "pre-commit: blocked — secret pattern match in $f:$(printf "%s\n" "$out" | head -1 | cut -d: -f1) (matched content NOT shown)" >&2
              exit 1 ;;
            1) ;;
            *)
              echo "pre-commit: FAILED — scanner error (grep exit $ec) scanning $f; refusing to certify it clean" >&2
              exit 1 ;;
          esac
        done < "$1"
      }
      scan_file "$baseline_patterns"
      scan_file "$user_patterns"
    ' _ {} "$PATTERNS_FILE" "$BASELINE_PATTERNS_FILE" "$BLOB_FILE"
done

# Also scan all staged files against the full pattern list.
# These paths come from `git diff --cached --name-only`, so the blob exists
# in the index by definition — read it via `git show ":$f"` rather than the
# working tree. The `git cat-file -e` guard is defense-in-depth in case the
# index changed between the diff and the scan.
git diff --cached --name-only -z | \
  xargs -0 -I{} bash -c 'set -eo pipefail
    f="$1"; user_patterns="$2"; baseline_patterns="$3"; blob="$4"
    case "$f" in
      *[!a-zA-Z0-9_/.-]*|..|../*|*/..|*/../*|.*|-*|/*)
        echo "pre-commit: path failed allowlist validation: $f" >&2; exit 1 ;;
    esac
    git cat-file -e ":$f" 2>/dev/null || exit 0
    if ! git show ":$f" >"$blob" 2>/dev/null; then
      echo "pre-commit: FAILED — cannot read staged blob for $f; refusing to certify it clean" >&2
      exit 1
    fi
    scan_staged() {
      while IFS= read -r pat || [ -n "$pat" ]; do
        [ -z "$pat" ] && continue
        set +e
        out=$(grep -aEn -- "$pat" "$blob")
        ec=$?
        set -e
        case "$ec" in
          0)
            echo "pre-commit: blocked — secret pattern match in staged content of $f:$(printf "%s\n" "$out" | head -1 | cut -d: -f1) (matched content NOT shown)" >&2
            exit 1 ;;
          1) ;;
          *)
            echo "pre-commit: FAILED — scanner error (grep exit $ec) scanning staged content of $f; refusing to certify it clean" >&2
            exit 1 ;;
        esac
      done < "$1"
    }
    scan_staged "$baseline_patterns"
    scan_staged "$user_patterns"
  ' _ {} "$PATTERNS_FILE" "$BASELINE_PATTERNS_FILE" "$BLOB_FILE"

# END claude-secret-guard
